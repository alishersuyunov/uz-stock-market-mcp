Package: anytime
Type: Package
Title: Anything to 'POSIXct' or 'Date' Converter
Version: 0.3.13
Date: 2026-04-13
Authors@R: person("Dirk", "Eddelbuettel", role = c("aut", "cre"), email = "edd@debian.org",
